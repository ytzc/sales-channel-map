# =========================================================================
# 通路戰情地圖系統 (Channel War Map) - 本機環境變數範例檔
# 請複製此檔案並重新命名為 .env.local，然後填入您的真實 Key 憑證值。
# =========================================================================

# 1. Mapbox GL 地圖 Access Token (地圖頁面真實地圖渲染所需)
# 可至 Mapbox 官網 (https://www.mapbox.com/) 免費註冊帳號並取得一個 Access Token
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_access_token_here

# 2. 未來實體連線 Supabase 資料庫與 API 所需環境變數
# 目前 MVP 階段為 100% 本機 Mock Data 運作，以下變數可先保留空白
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
